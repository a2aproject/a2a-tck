# A2A TCK Environment Configuration
# Copy this file to .env and modify values as needed

# Streaming timeout configuration (in seconds)
# Controls timeout values for SSE (Server-Sent Events) streaming tests
# Default: 2.0 seconds if not specified
# Examples:
#   TCK_STREAMING_TIMEOUT=1.0    # Faster timeouts for quick tests
#   TCK_STREAMING_TIMEOUT=5.0    # Slower timeouts for slower systems
#   TCK_STREAMING_TIMEOUT=10.0   # Very slow timeouts for debugging
TCK_STREAMING_TIMEOUT=2.0

# ============================================================================
# Authentication Configuration
# ============================================================================
# Configure authentication credentials for testing SUTs that require auth
# The TCK will automatically inject these headers into all requests

# --- Option 1: Bearer Token Authentication ---
# Recommended for JWT or OAuth2 bearer tokens
# A2A_AUTH_TYPE=bearer
# A2A_AUTH_TOKEN=your-bearer-token-here

# --- Option 2: Basic Authentication ---
# For HTTP Basic Auth (username/password)
# A2A_AUTH_TYPE=basic
# A2A_AUTH_USERNAME=your-username
# A2A_AUTH_PASSWORD=your-password

# --- Option 3: API Key Authentication ---
# For API key in custom header
# A2A_AUTH_TYPE=apikey
# A2A_AUTH_TOKEN=your-api-key-here
# A2A_AUTH_HEADER=X-API-Key  # Optional: defaults to X-API-Key

# --- Option 4: Custom Header Authentication ---
# For any custom authentication header
# A2A_AUTH_TYPE=custom
# A2A_AUTH_TOKEN=your-token-here
# A2A_AUTH_HEADER=X-Custom-Auth-Header

# --- Option 5: Multiple Custom Headers (JSON format) ---
# For complex auth scenarios with multiple headers
# A2A_AUTH_HEADERS={"Authorization":"Bearer token","X-API-Key":"key123"}

# ============================================================================
# Examples for Common Scenarios
# ============================================================================

# Example 1: JWT Bearer Token
# A2A_AUTH_TYPE=bearer
# A2A_AUTH_TOKEN=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Example 2: API Key in custom header
# A2A_AUTH_TYPE=apikey
# A2A_AUTH_TOKEN=sk_test_1234567890
# A2A_AUTH_HEADER=X-API-Key

# Example 3: Basic Auth
# A2A_AUTH_TYPE=basic
# A2A_AUTH_USERNAME=admin
# A2A_AUTH_PASSWORD=password123

# Example 4: Multiple headers (advanced)
# A2A_AUTH_HEADERS={"Authorization":"Bearer token","X-Request-ID":"test-run-001"}
